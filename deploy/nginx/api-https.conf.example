# Этап 2 (после выпуска сертификата): HTTPS + редирект с HTTP.
# Скопировать в conf.d/api.conf и перезапустить nginx:
#   cp deploy/nginx/api-https.conf.example deploy/nginx/conf.d/api.conf
#   docker compose -f docker-compose.prod.yml restart nginx

server {
    listen 80;
    server_name api.uaartist.ru;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name api.uaartist.ru;

    ssl_certificate /etc/letsencrypt/live/api.uaartist.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.uaartist.ru/privkey.pem;

    client_max_body_size 20m;

    # Год HTTPS-only для браузеров. Остальные security-заголовки API шлёт Django.
    add_header Strict-Transport-Security "max-age=31536000" always;

    # Логин в админку: не больше 10 попыток в минуту с IP (+burst 10) —
    # защита от перебора пароля. Зона admin_login объявлена в 00-default.conf.
    location = /admin/login/ {
        limit_req zone=admin_login burst=10 nodelay;
        limit_req_status 429;
        proxy_pass http://backend:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /static/ {
        alias /srv/static/;
        expires 7d;
    }

    location /media/ {
        alias /srv/media/;
        expires 30d;
    }

    location / {
        proxy_pass http://backend:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
