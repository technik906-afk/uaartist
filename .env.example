# Copy this file to `.env` (kept out of git) before running docker compose.
# For host-run backend (no Docker) change DATABASE_URL host `db` -> `localhost`.

# ── Django ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=dev-insecure-change-me-please
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── ЮKassa (онлайн-оплата; пусто = отключена) ───────────────────────
# Тестовый магазин: yookassa.ru → Интеграция → Ключи API (test_...)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Код ставки НДС для чеков 54-ФЗ (1 = без НДС/УСН)
YOOKASSA_VAT_CODE=1

# ── Telegram (уведомления о заказах; пусто = отключено) ─────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (по умолчанию console — письма в логи; для прода раскомментировать) ──
# SMTP.bz: хост/логин/пароль — в ЛК после регистрации; домен uaartist.ru
# должен быть подтверждён (SPF + DKIM в DNS Selectel), From — на этом домене.
#DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#DJANGO_EMAIL_HOST=connect.smtp.bz
#DJANGO_EMAIL_PORT=587
#DJANGO_EMAIL_HOST_USER=
#DJANGO_EMAIL_HOST_PASSWORD=
#DJANGO_DEFAULT_FROM_EMAIL=uaartist <noreply@uaartist.ru>

# ── Email-дубли уведомлений (Telegram из РФ ненадёжен) ──────────────
# Письмо владельцу о каждом заказе (пусто = выключено):
#ORDER_NOTIFY_EMAIL=
# 500-ки на почту (список через запятую; работает при DEBUG=False):
#DJANGO_ADMINS=

# ── Database (shared by Django and the Postgres container) ──────────
POSTGRES_DB=uaartist
POSTGRES_USER=uaartist
POSTGRES_PASSWORD=uaartist
DATABASE_URL=postgres://uaartist:uaartist@db:5432/uaartist
